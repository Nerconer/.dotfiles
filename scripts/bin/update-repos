#!/bin/bash
#
# Script to update all repositories at once

# Exit on fail
set -e

CURRENT_PATH="$(pwd)"

for f in */; do # Match only directories
    # $f is a directory
    printf "\n\n\n***** Updating '%s' *****\n" "$f"

    cd "$f"

    printf "\n  1. Fetching latest repository version..."
    git fetch --all --prune

    # Detect the default branch (main, master, ...) instead of hardcoding it
    branch="$(git remote show origin | sed -n 's/.*HEAD branch: //p')"
    git checkout "$branch"
    git pull origin "$branch"

    printf "\n  2. Updated successfully"

    cd "$CURRENT_PATH"
done
