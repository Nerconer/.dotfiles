function setup_backup() {
	BACKUP_DIR=$HOME/dotfiles-backup

	title "Creating backup directory at $BACKUP_DIR"

	mkdir -p "$BACKUP_DIR"

	for file in "$HOME/.config/nvim" "$HOME/.vim" "$HOME/.vimrc" "$HOME/.zshrc" "$HOME/.zprofile" "$HOME/.gitconfig" "$HOME/.tmux.conf"; do
		if [ -e "$file" ] && [ ! -L "$file" ]; then
			echo "Backing up $file"
			cp -rf "$file" "$BACKUP_DIR"
		else
			warning "$file does not exist at this location or is a symlink"
		fi
	done
}

function setup_symlinks() {
	title "Setting up symbolic links"

	if ! command_exists 'stow'; then
		error "stow is not installed. Run './install homebrew' first"
	fi

	# Pre-create ~/.ssh so stow links only the config file, never the
	# whole directory (private keys must stay outside the repo)
	mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"

	# Move real files out of the way so stow doesn't abort on conflicts;
	# symlinks are left alone (stow --restow refreshes them)
	for target in "$HOME/.zshrc" "$HOME/.zprofile" "$HOME/.zsh_profile" "$HOME/.gitconfig" "$HOME/.gitignore_global" "$HOME/.nanorc" "$HOME/.tmux.conf" "$HOME/.ssh/config"; do
		if [ -e "$target" ] && [ ! -L "$target" ]; then
			warning "Moving existing $target to $target.backup"
			mv "$target" "$target.backup"
		fi
	done

	for folder in "${LINKS[@]}"; do
		stow --restow "$folder"
	done

	if [ -e "$HOME/.local/share/nvim/site/autoload/plug.vim" ]; then
		echo "vim-plug already exists... Skipping"
	else
		echo "Installing vim-plug"
		curl -fLo "${XDG_DATA_HOME:-$HOME/.local/share}"/nvim/site/autoload/plug.vim --create-dirs \
			https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
		echo "Installing nvim plugins..."
		nvim --headless +PlugInstall +qall
	fi
}

function setup_git() {
	title "Setting up Git"

	defaultName=$(git config user.name)
	defaultEmail=$(git config user.email)

	read -rp "Name [$defaultName] " name
	read -rp "Email [$defaultEmail] " email

	# ~/.gitconfig.local is included from git/.gitconfig and kept out of version control
	git config -f ~/.gitconfig.local user.name "${name:-$defaultName}"
	git config -f ~/.gitconfig.local user.email "${email:-$defaultEmail}"
}

function setup_homebrew() {
	title "Setting up Homebrew"

	if ! command_exists 'brew'; then
		echo "Homebrew not installed. Installing..."
		# Run non-interactively so that the script doesn't pause for user input
		NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
	fi

	# Make brew available in this script no matter the platform prefix;
	# interactive shells get this from zsh/.zprofile
	for brew_path in /opt/homebrew/bin/brew /usr/local/bin/brew /home/linuxbrew/.linuxbrew/bin/brew; do
		if [ -x "$brew_path" ]; then
			eval "$("$brew_path" shellenv)"
			break
		fi
	done

	# install brew dependencies from Brewfile
	brew bundle
}

function setup_shell() {
	title "Configuring Shell"

	if [ -d "$HOME/.oh-my-zsh" ]; then
		echo "Oh My Zsh already installed, skipping..."
	else
		echo "Installing Oh My Zsh..."
		# --unattended: don't switch shells or start zsh mid-script
		# --keep-zshrc: never replace the stowed .zshrc symlink
		sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended --keep-zshrc
	fi

	# External plugins referenced from .zshrc (not bundled with Oh My Zsh)
	zsh_custom="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
	if [ ! -d "$zsh_custom/plugins/zsh-autosuggestions" ]; then
		git clone https://github.com/zsh-users/zsh-autosuggestions "$zsh_custom/plugins/zsh-autosuggestions"
	fi
	if [ ! -d "$zsh_custom/plugins/zsh-syntax-highlighting" ]; then
		git clone https://github.com/zsh-users/zsh-syntax-highlighting "$zsh_custom/plugins/zsh-syntax-highlighting"
	fi

	# Register zsh as a valid login shell and make it the default
	if ! grep -q "$(command -v zsh)" /etc/shells; then
		command -v zsh | sudo tee -a /etc/shells
	fi
	if [ "$(basename "$SHELL")" != "zsh" ]; then
		chsh -s "$(command -v zsh)"
	fi
}

function setup_vscode() {
	title "Setting up VS Code"

	if ! command_exists 'code'; then
		warning "VS Code CLI not found, skipping (install it via brew bundle first)"
		return 0
	fi

	if [ "$(uname)" = "Darwin" ]; then
		vscode_user="$HOME/Library/Application Support/Code/User"
	else
		vscode_user="$HOME/.config/Code/User"
	fi
	mkdir -p "$vscode_user"

	# Seed settings/keybindings only when missing: the repo keeps a sanitized
	# baseline, the live files may grow machine-specific entries afterwards
	for file in settings.json keybindings.json; do
		if [ -e "$vscode_user/$file" ]; then
			echo "$file already exists... Skipping"
		else
			echo "Copying $file"
			cp "vscode/$file" "$vscode_user/$file"
		fi
	done

	echo "Installing missing extensions..."
	installed=$(code --list-extensions)
	while IFS= read -r extension; do
		if ! echo "$installed" | grep -qix "$extension"; then
			code --install-extension "$extension"
		fi
	done < vscode/extensions.txt
}

function setup_macos() {
	title "Setting up macOS defaults"

	if [ "$(uname)" != "Darwin" ]; then
		warning "Not macOS, skipping"
		return 0
	fi

	./macos/defaults
}
